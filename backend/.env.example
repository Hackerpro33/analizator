###########
# Core API
###########
API_PREFIX=/api/v1
ENVIRONMENT=development
SERVICE_NAME=insight-backend
LOG_LEVEL=INFO

###########
# Network / CORS / HTTPS
###########
FRONTEND_ORIGIN=http://localhost:5173
ADDITIONAL_CORS_ORIGINS=
ALLOWED_HOSTS=localhost,127.0.0.1
FORCE_HTTPS_REDIRECT=1
HSTS_MAX_AGE=31536000

###########
# Upload restrictions
###########
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=.csv,.tsv,.xlsx,.xls
CLAMAV_SCAN_URL=

###########
# Object storage (S3 / MinIO)
###########
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=local
OBJECT_STORAGE_SECRET_KEY=localsecret
OBJECT_STORAGE_BUCKET=insight-artifacts
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PATH_STYLE=1
OBJECT_STORAGE_USE_SSL=0
OBJECT_STORAGE_LOCAL_ROOT=/app/uploads

###########
# Database (PostgreSQL recommended)
###########
DATABASE_URL=postgresql+psycopg2://app:password@postgres:5432/app

###########
# Auth and roles
###########
AUTH_JWT_SECRET=change-me
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRES_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRES_MINUTES=10080
AUTH_COOKIE_SECURE=0
ADMIN_INVITE_CODE=
SECURITY_INVITE_CODE=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_FULL_NAME=System Admin
USER_STORE_PATH=/app/data/users.json

###########
# Background processing / Redis
###########
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_ENABLED=0
TASK_QUEUE_NAME=insight-analytics
TASK_DEFAULT_TIMEOUT=600

###########
# Observability and security
###########
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_INSECURE=1

###########
# Misc
###########
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_RETRIES=2
ALERT_WEBHOOK_TIMEOUT=5
